{
  "name": "@vafast/html",
  "version": "0.0.6",
  "description": "HTML rendering plugin for Vafast framework",
  "type": "module",
  "author": {
    "name": "Vafast Team",
    "url": "https://github.com/vafast",
    "email": "team@vafast.dev"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    }
  },
  "keywords": [
    "vafast",
    "html",
    "jsx",
    "rendering"
  ],
  "homepage": "https://github.com/vafast/vafast-html",
  "repository": {
    "type": "git",
    "url": "https://github.com/vafast/vafast-html"
  },
  "bugs": "https://github.com/vafast/vafast-html/issues",
  "license": "MIT",
  "scripts": {
    "build": "tsdown",
    "dev": "npx tsx watch example/index.ts",
    "test": "npx vitest run",
    "release": "npm run build && npm run test && npx bumpp && npm publish --access=public",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "vafast": "<2.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "devDependencies": {
    "@types/node": "^24.0.0",
    "rimraf": "^6.0.1",
    "tsdown": "^0.19.0-beta.4",
    "typescript": "^5.4.5",
    "vitest": "^4.0.16",
    "vafast": "^0.8.1"
  },
  "dependencies": {
    "@kitajs/html": "^4.1.0",
    "@kitajs/ts-html-plugin": "^4.0.1"
  }
}
